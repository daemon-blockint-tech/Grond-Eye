# ============================================================
# .env — committed to git (non-secret defaults)
# ============================================================
# This file is tracked by git. Only put non-secret values here.
# Prisma reads DATABASE_URL from this file.

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/grond

# ============================================================
# .env.local — NOT committed (secrets & API keys)
# ============================================================
# Copy everything below into a new file called .env.local
# .env.local is gitignored and overrides .env values.

# Auth Secret (REQUIRED — generate with: openssl rand -hex 32)
# Must remain stable across restarts to preserve sessions and tokens.
# For Docker: also set this in the host environment or a .env file
# at the project root so docker-compose can inject it.
AUTH_SECRET=

# Cesium Ion Access Token (optional — get one free at https://ion.cesium.com/)
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# Google Maps Platform — Photorealistic 3D Tiles (Map Tiles API must be enabled)
# Users can also add a key in Settings → API Keys (stored in browser localStorage).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Earth Engine (server-side basemap imagery)
# Service account JSON with Earth Engine enabled — never expose to the client.
# EARTHENGINE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Or point to a key file on disk (local dev):
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# EARTHENGINE_PROJECT=your-gcp-project-id

# Supabase — local CLI first (default for local / development)
# 1. Run: pnpm supabase:start
# 2. Keys below are the standard `supabase start` demo JWTs (local only).
# 3. Set SUPABASE_PREFER_LOCAL=false to force a hosted project instead.
SUPABASE_PREFER_LOCAL=true
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nk0.EGIM96RAZx35lJzdJsyH-qQvRHR6iNth8OIetmNb2x0
# Prisma can use local Supabase Postgres (port 54322) instead of docker `db` on 5432:
# SUPABASE_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres

# OpenSky Network — multi-account credential rotation
# Comma-separated clientId:clientSecret pairs.
# Example: OPENSKY_CREDENTIALS=acct1-id:acct1-secret,acct2-id:acct2-secret
OPENSKY_CREDENTIALS=

# ACLED API — Civil Unrest & Conflict data (free for non-commercial use)
# Register at https://developer.acleddata.com/ to obtain credentials.
# Data is updated weekly (Mondays) with global protest, riot, and violence events.
ACLED_EMAIL=
ACLED_PASSWORD=

# Marketplace Bridge Token — shared secret for marketplace → Grond install requests
# Generate any random string, then set the same value in the marketplace instance config.
GROND_BRIDGE_TOKEN=
# Legacy: WWV_BRIDGE_TOKEN=

# Default plugins enabled on boot for demo edition
# Comma-separated list of plugin IDs
NEXT_PUBLIC_DEMO_DEFAULT_PLUGINS=

# Edition: "local" | "cloud" | "demo"
NEXT_PUBLIC_GROND_EDITION=local
# Legacy (one release): NEXT_PUBLIC_WWV_EDITION=local

# Ops simulation scenarios (cloud edition: set true to enable Run/Stop on /ops)
# Enabled by default in development, local, and demo editions.
# SCENARIOS_ENABLED=true

# Plugin data engine (optional; defaults to localhost:5001 in local dev)
# NEXT_PUBLIC_GROND_PLUGIN_DATA_ENGINE_URL=http://localhost:5001

# Marketplace OAuth (deploy marketplace with grond JWT before enabling)
# NEXT_PUBLIC_GROND_MARKETPLACE_URL=https://marketplace.grond.dev

# Ops announcement banner (optional)
# NEXT_PUBLIC_OPS_BANNER_ENABLED=true
# NEXT_PUBLIC_OPS_BANNER_URL=https://example.com/docs

# Optional Database Teardown
# If set to true, terminating 'pnpm run dev' (Ctrl+C) will automatically
# stop the local database container (freeing up port 5432).
GROND_TEARDOWN_DB_ON_EXIT=false
# Legacy: WWV_TEARDOWN_DB_ON_EXIT=false

# Demo Admin Secret (demo edition only)
# Allows operator plugin management on the demo instance via x-grond-admin-secret header.
# Generate any random string. Only set this on the demo deployment.
# GROND_DEMO_ADMIN_SECRET=
# Legacy: WWV_DEMO_ADMIN_SECRET=

# ReactBits License Key
REACTBITS_LICENSE_KEY=